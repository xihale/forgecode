{
  "title": "TaskInput",
  "description": "Input structure for the Task tool - delegates work to specialized agents",
  "type": "object",
  "properties": {
    "agent_id": {
      "description": "Agent ID (e.g. \"forge\", \"muse\", \"sage\").",
      "type": "string"
