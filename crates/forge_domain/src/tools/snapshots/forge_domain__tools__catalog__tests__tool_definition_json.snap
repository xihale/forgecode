---
source: crates/forge_domain/src/tools/catalog.rs
expression: tools
---
{
  "title": "FSRead",
  "type": "object",
  "properties": {
    "file_path": {
      "description": "Absolute path to file to read.",
      "type": "string"
    },
    "range": {
      "description": "Optional line range for partial reads.",
      "type": "object",
      "properties": {
        "end_line": {
          "description": "1-based last line (inclusive).",
          "type": "integer",
          "format": "int32",
          "nullable": true
        },
        "start_line": {
          "description": "1-based first line (inclusive).",
          "type": "integer",
          "format": "int32",
          "nullable": true
        }
      },
      "additionalProperties": false,
      "nullable": true
    },
    "show_line_numbers": {
      "description": "Show line numbers. Defaults to true.",
      "type": "boolean",
      "default": true
    }
  },
  "additionalProperties": false,
  "required": [
    "file_path"
  ]
}
{
  "title": "FSWrite",
  "type": "object",
  "properties": {
    "content": {
      "description": "Content to write.",
      "type": "string"
    },
    "file_path": {
      "description": "Absolute path to file.",
      "type": "string"
    },
    "overwrite": {
      "description": "Overwrite existing files. Error if false and file exists.",
      "type": "boolean"
    }
  },
  "required": [
    "file_path",
    "content"
  ]
}
{
  "title": "FSSearch",
  "type": "object",
  "properties": {
    "-A": {
      "description": "Lines after match (rg -A). Requires output_mode: \"content\".",
      "type": "integer",
      "format": "uint32",
      "minimum": 0,
      "nullable": true
    },
    "-B": {
      "description": "Lines before match (rg -B). Requires output_mode: \"content\".",
      "type": "integer",
      "format": "uint32",
      "minimum": 0,
      "nullable": true
    },
    "-C": {
      "description": "Lines before and after match (rg -C). Requires output_mode: \"content\".",
      "type": "integer",
      "format": "uint32",
      "minimum": 0,
      "nullable": true
    },
    "-i": {
      "description": "Case insensitive search (rg -i).",
      "type": "boolean",
      "nullable": true
    },
    "-n": {
      "description": "Show line numbers (rg -n). Requires output_mode: \"content\".",
      "type": "boolean",
      "nullable": true
    },
    "glob": {
      "description": "Glob filter (e.g. \"*.js\", \"*.{ts,tsx}\").",
      "type": "string",
      "nullable": true
    },
    "head_limit": {
      "description": "Limit output to first N entries. Works across all output modes.",
      "type": "integer",
      "format": "uint32",
      "minimum": 0,
      "nullable": true
    },
    "multiline": {
      "description": "Multiline mode: . matches newlines (rg -U --multiline-dotall).",
      "type": "boolean",
      "nullable": true
    },
    "offset": {
      "description": "Skip first N entries before applying head_limit.",
      "type": "integer",
      "format": "uint32",
      "minimum": 0,
      "nullable": true
    },
    "output_mode": {
      "description": "Output mode: \"content\" (lines), \"files_with_matches\" (paths), \"count\".",
      "type": "string",
      "enum": [
        "content",
        "files_with_matches",
        "count",
        null
      ],
      "nullable": true
    },
    "path": {
      "description": "File or directory to search in. Defaults to cwd.",
      "type": "string",
      "nullable": true
    },
    "pattern": {
      "description": "Regex pattern to search for.",
      "type": "string"
    },
    "type": {
      "description": "File type (rg --type). E.g. js, py, rust, go, java.",
      "type": "string",
      "nullable": true
    }
  },
  "required": [
    "pattern"
  ]
}
{
  "title": "SemanticSearch",
  "type": "object",
  "properties": {
    "queries": {
      "description": "2-3 varied queries recommended for best results.",
      "type": "array",
      "items": {
        "description": "A paired query and use_case for semantic search.",
        "type": "object",
        "properties": {
          "query": {
            "description": "Embedding query: WHAT the code does. Use specific technical terms.",
            "type": "string"
          },
          "use_case": {
            "description": "Reranking query: WHY you need this code. Include keywords (struct/trait/impl/fn).",
            "type": "string"
          }
        },
        "required": [
          "query",
          "use_case"
        ]
      }
    }
  },
  "required": [
    "queries"
  ]
}
{
  "title": "FSRemove",
  "type": "object",
  "properties": {
    "path": {
      "description": "Path of file to remove (absolute).",
      "type": "string"
    }
  },
  "required": [
    "path"
  ]
}
{
  "title": "FSPatch",
  "type": "object",
  "properties": {
    "file_path": {
      "description": "Absolute path to file to modify.",
      "type": "string"
    },
    "new_string": {
      "description": "Replace old_string with new_string. Must differ.",
      "type": "string"
    },
    "old_string": {
      "description": "Text to replace.",
      "type": "string"
    },
    "replace_all": {
      "description": "Replace all occurrences of old_string (default false)\nReplace all occurrences (default false).",
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "file_path",
    "old_string",
    "new_string"
  ]
}
{
  "title": "FSMultiPatch",
  "type": "object",
  "properties": {
    "edits": {
      "description": "Edit operations applied sequentially.",
      "type": "array",
      "items": {
        "description": "A single edit operation in a multi-patch.",
        "type": "object",
        "properties": {
          "new_string": {
            "description": "Replace old_string with new_string. Must differ.",
            "type": "string"
          },
          "old_string": {
            "description": "Text to replace.",
            "type": "string"
          },
          "replace_all": {
            "description": "Replace all occurrences (default false).",
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "old_string",
          "new_string"
        ]
      }
    },
    "file_path": {
      "description": "Absolute path to file to modify.",
      "type": "string"
    }
  },
  "required": [
    "file_path",
    "edits"
  ]
}
{
  "title": "FSUndo",
  "type": "object",
