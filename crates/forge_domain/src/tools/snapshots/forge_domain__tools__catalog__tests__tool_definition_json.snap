    "session_id": {
      "description": "Optional session ID for continuing existing sessions.",
      "type": "string",
      "nullable": true
    },
    "tasks": {
      "description": "Task descriptions for parallel execution by the agent.",
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
