{
  "title": "TodoWrite",
  "type": "object",
  "properties": {
    "todos": {
      "description": "Todo items to add/update. `content` is unique key. `cancelled` removes item.",
      "type": "array",
      "items": {
        "description": "A single todo item. `content` is the unique key for matching.",
        "type": "object",
        "properties": {
          "content": {
            "description": "Task description. Used as unique key to match existing todos.",
            "type": "string"
          },
          "status": {
            "description": "`pending`|`in_progress`|`completed`|`cancelled`",
            "type": "string",
            "enum": [
              "pending",
              "in_progress",
              "completed",
              "cancelled"
            ]
          }
        },
        "required": [
          "content",
          "status"
        ]
      }
    }
  },
  "required": [
    "todos"
  ]
}
{
  "title": "TodoRead",
